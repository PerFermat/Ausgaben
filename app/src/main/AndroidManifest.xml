<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <!-- Für die optionalen GPS-Koordinaten in der Notiz (nur lokal, kein externer Dienst). -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- osmdroid empfiehlt Netzwerkstatus für das Nachladen der Kartenkacheln. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".AusgabenApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Ausgaben">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.SettingsActivity"
            android:exported="false"
            android:label="@string/settings_title"
            android:parentActivityName=".ui.MainActivity" />

        <activity
            android:name=".ui.BookingEditActivity"
            android:exported="false"
            android:label="@string/edit_title"
            android:parentActivityName=".ui.MainActivity" />

        <activity
            android:name=".ui.AliasActivity"
            android:exported="false"
            android:label="@string/alias_manage_title"
            android:parentActivityName=".ui.SettingsActivity" />

        <activity
            android:name=".ui.AliasEditActivity"
            android:exported="false"
            android:label="@string/alias_edit_title"
            android:parentActivityName=".ui.AliasActivity" />

        <activity
            android:name=".ui.MapPickerActivity"
            android:exported="false"
            android:label="@string/map_pick_title"
            android:parentActivityName=".ui.AliasEditActivity" />

        <activity
            android:name=".ui.AnalysisActivity"
            android:exported="false"
            android:label="@string/analysis_title"
            android:parentActivityName=".ui.MainActivity" />

        <activity
            android:name=".ui.BalanceActivity"
            android:exported="false"
            android:label="@string/balance_title"
            android:parentActivityName=".ui.MainActivity" />

        <activity
            android:name=".ui.DepotActivity"
            android:exported="false"
            android:label="@string/depot_title"
            android:parentActivityName=".ui.MainActivity" />

        <activity
            android:name=".ui.SecurityHistoryActivity"
            android:exported="false"
            android:parentActivityName=".ui.DepotActivity" />

        <activity
            android:name=".ui.DepotChartActivity"
            android:exported="false"
            android:parentActivityName=".ui.DepotActivity" />

        <activity
            android:name=".ui.PlaceHistoryActivity"
            android:exported="false"
            android:parentActivityName=".ui.BalanceActivity" />

        <activity
            android:name=".ui.LockActivity"
            android:exported="false"
            android:theme="@style/Theme.Ausgaben" />

        <!-- Homescreen-Widgets (drei Größen: klein/mittel/groß). -->
        <receiver
            android:name=".widget.WidgetSmall"
            android:exported="true"
            android:label="@string/widget_small_desc">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_small_info" />
        </receiver>

        <receiver
            android:name=".widget.WidgetMedium"
            android:exported="true"
            android:label="@string/widget_medium_desc">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_medium_info" />
        </receiver>

        <receiver
            android:name=".widget.WidgetLarge"
            android:exported="true"
            android:label="@string/widget_large_desc">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_large_info" />
        </receiver>

        <!-- Der Wear-Data-Layer-Listener (Google Play Services) wird nur im „full"-Flavor registriert:
             siehe app/src/full/AndroidManifest.xml. Der „foss"-Flavor (F-Droid) enthält kein GMS. -->

    </application>

</manifest>
