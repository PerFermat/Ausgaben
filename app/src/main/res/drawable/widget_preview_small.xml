<?xml version="1.0" encoding="utf-8"?>
<!-- Schematische Vorschau für den Widget-Auswahldialog (previewImage-Fallback vor API 31): quadratisch
     (1×1), Wallet-Punkt links, zwei angedeutete Textzeilen rechts – kein echter Screenshot. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <size android:width="96dp" android:height="96dp" />
            <solid android:color="@color/widget_bg" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item
        android:width="28dp"
        android:height="28dp"
        android:left="10dp"
        android:gravity="center_vertical|left">
        <shape android:shape="oval">
            <solid android:color="#2E7D32" />
        </shape>
    </item>
    <item
        android:left="46dp"
        android:right="14dp"
        android:top="36dp"
        android:height="8dp"
        android:gravity="top">
        <shape android:shape="rectangle">
            <solid android:color="@color/widget_text_secondary" />
            <corners android:radius="4dp" />
        </shape>
    </item>
    <item
        android:left="46dp"
        android:right="18dp"
        android:top="52dp"
        android:height="14dp"
        android:gravity="top">
        <shape android:shape="rectangle">
            <solid android:color="@color/widget_text" />
            <corners android:radius="7dp" />
        </shape>
    </item>
</layer-list>
