<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/green_primary"
        android:theme="@style/ThemeOverlay.Ausgaben.Toolbar"
        app:navigationIcon="@drawable/ic_back"
        app:title="@string/edit_title"
        app:titleTextColor="@color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnExpense"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/type_expense" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTransfer"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/type_transfer" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnIncome"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/type_income" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- Nur in der reinen Ansicht: große farbige Typ-Überschrift statt der Umschaltknöpfe. -->
            <TextView
                android:id="@+id/typeHeading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="26sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/date_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:clickable="true"
                        android:cursorVisible="false"
                        android:inputType="none" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToday"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textColor="@color/button_accent"
                    app:strokeColor="@color/button_accent"
                    android:text="@string/today"
                    android:visibility="gone" />
            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/amountLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/amount_hint"
                app:helperTextEnabled="true"
                app:helperText="@string/amount_calc_help">

                <!-- „phone" statt „numberDecimal": ein Ziffernblock, der auch + und * anbietet, damit sich
                     kleine Rechnungen (10+20*3) eintippen lassen. Erlaubte Zeichen und Struktur regelt der
                     CalcInputFilter im Code (kein android:digits/KeyListener – die Tastatur bleibt so der
                     Ziffernblock). -->
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editAmount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/payeeLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/payee_hint">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/editPayee"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="64dp"
                    android:paddingVertical="14dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="18sp"
                    android:completionThreshold="1"
                    android:inputType="textCapWords" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/accountLayout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/account_hint">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/editAccount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="64dp"
                    android:paddingVertical="14dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="18sp"
                    android:inputType="none" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/placeLayout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/place_hint">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/editPlace"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="64dp"
                    android:paddingVertical="14dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="18sp"
                    android:inputType="none" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/accountToLayout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/transfer_to"
                android:visibility="gone">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/editAccountTo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="64dp"
                    android:paddingVertical="14dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="18sp"
                    android:inputType="none" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/placeToLayout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/transfer_place_to"
                android:visibility="gone">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/editPlaceTo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="64dp"
                    android:paddingVertical="14dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="18sp"
                    android:inputType="none" />
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:id="@+id/splitSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/split_categories"
                    android:textColor="@color/grey_text"
                    android:textSize="14sp" />

                <LinearLayout
                    android:id="@+id/splitContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/note_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editNote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top|start"
                    android:minLines="4"
                    android:inputType="textCapSentences|textMultiLine" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- GPS-Koordinaten als eigene, nicht editierbare Ausgabezeile (Wert + Karten-Icon). -->
            <LinearLayout
                android:id="@+id/rowGps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/textGps"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="14sp" />

                <ImageButton
                    android:id="@+id/btnNoteMap"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_mylocation"
                    android:contentDescription="@string/alias_map" />
            </LinearLayout>

            <!-- Beleg-Dateiname als eigene Ausgabezeile (Wert + Bild-/Kamera-Icon). -->
            <LinearLayout
                android:id="@+id/rowReceipt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/textReceipt"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="14sp" />

                <ImageButton
                    android:id="@+id/btnReceiptDelete"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_delete"
                    android:contentDescription="@string/receipt_remove"
                    android:visibility="gone" />

                <ImageButton
                    android:id="@+id/btnReceipt"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_camera"
                    android:contentDescription="@string/receipt_view_title" />
            </LinearLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchExported"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/mark_exported"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveNew"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/new_booking" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUpdate"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/button_accent"
                app:strokeColor="@color/button_accent"
                android:text="@string/update_booking"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDelete"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/delete_booking"
                app:strokeColor="@color/expense_red"
                android:textColor="@color/expense_red"
                android:visibility="gone" />

            <!-- Nur in der reinen Ansicht: Kontostand vor/nach dieser Buchung. -->
            <TextView
                android:id="@+id/textBalanceBefore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textSize="16sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/textBalanceAfter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="16sp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

    <!-- Eigene Rechentastatur; nur sichtbar, wenn das Betragsfeld aktiv ist. -->
    <de.spahr.ausgaben.ui.CalcKeyboardView
        android:id="@+id/calcKeyboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone" />
</LinearLayout>
