<?xml version="1.0" encoding="utf-8"?>
<androidx.wear.widget.BoxInsetLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:boxedEdges="all">

        <!-- Zustand A: Typ wählen -->
        <LinearLayout
            android:id="@+id/typeSelection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="6dp">

            <!-- Grauer Wechsel-Knopf: Konto/Ort durchschalten (oberhalb von „Buchung erfassen", mittig). -->
            <ImageButton
                android:id="@+id/btnCycle"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_circle"
                android:backgroundTint="#757575"
                android:contentDescription="@string/wear_switch"
                android:scaleType="center"
                android:src="@drawable/ic_cycle"
                android:visibility="gone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/wear_title"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:baselineAligned="false"
                android:weightSum="3">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageButton
                        android:id="@+id/btnIncome"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_circle"
                        android:backgroundTint="@color/type_income"
                        android:contentDescription="@string/wear_type_income"
                        android:scaleType="center"
                        android:src="@drawable/ic_plus" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageButton
                        android:id="@+id/btnTransfer"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_circle"
                        android:backgroundTint="@color/type_transfer"
                        android:contentDescription="@string/wear_type_transfer"
                        android:scaleType="center"
                        android:src="@drawable/ic_swap" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageButton
                        android:id="@+id/btnExpense"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_circle"
                        android:backgroundTint="@color/type_expense"
                        android:contentDescription="@string/wear_type_expense"
                        android:scaleType="center"
                        android:src="@drawable/ic_minus" />
                </LinearLayout>
            </LinearLayout>

            <!-- Konto/Ort-Saldo vom Phone (z. B. „Geldbeutel: 70,00 €"); leer → ausgeblendet.
                 Schriftgröße wie im Tile (ExpenseTileService: 12sp). Gibt es noch nicht übertragene
                 Einträge, steht hier stattdessen der Grund dafür. -->
            <TextView
                android:id="@+id/balanceView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Zustand B: erkannter Text + Abbrechen (10 s) -->
        <LinearLayout
            android:id="@+id/confirmView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/confirmType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/confirmText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/wear_cancel" />

            <!-- Nur im „Sprich jetzt"-Zustand: stille Zifferneingabe öffnen. -->
            <ImageButton
                android:id="@+id/btnNumberPad"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_circle"
                android:backgroundTint="#455A64"
                android:contentDescription="@string/number_entry"
                android:scaleType="center"
                android:src="@drawable/ic_dialpad"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Zustand C: stille Zifferneingabe (Zahlenblock) -->
        <ScrollView
            android:id="@+id/numberView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:padding="4dp">

                <TextView
                    android:id="@+id/numberDisplay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:minHeight="26dp"
                    android:text="0"
                    android:textColor="@android:color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:columnCount="3">

                    <Button android:id="@+id/btnD1" style="@style/WearKey" android:text="1" />
                    <Button android:id="@+id/btnD2" style="@style/WearKey" android:text="2" />
                    <Button android:id="@+id/btnD3" style="@style/WearKey" android:text="3" />
                    <Button android:id="@+id/btnD4" style="@style/WearKey" android:text="4" />
                    <Button android:id="@+id/btnD5" style="@style/WearKey" android:text="5" />
                    <Button android:id="@+id/btnD6" style="@style/WearKey" android:text="6" />
                    <Button android:id="@+id/btnD7" style="@style/WearKey" android:text="7" />
                    <Button android:id="@+id/btnD8" style="@style/WearKey" android:text="8" />
                    <Button android:id="@+id/btnD9" style="@style/WearKey" android:text="9" />
                    <Button android:id="@+id/btnComma" style="@style/WearKey" android:text="," />
                    <Button android:id="@+id/btnD0" style="@style/WearKey" android:text="0" />
                    <Button android:id="@+id/btnBack" style="@style/WearKey" android:text="⌫" />
                </GridLayout>

                <ImageButton
                    android:id="@+id/btnEnter"
                    android:layout_width="52dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_circle"
                    android:backgroundTint="@color/type_income"
                    android:contentDescription="@string/wear_cancel"
                    android:scaleType="center"
                    android:src="@drawable/ic_check" />
            </LinearLayout>
        </ScrollView>
    </FrameLayout>
</androidx.wear.widget.BoxInsetLayout>
